{
  "name": "uptimizer",
  "private": true,
  "version": "1.0.0",
  "description": "All-in-one Windows network toolkit for gamers and IT professionals.",
  "author": "Uptimizer",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "concurrently \"tsc -b\" \"tsc -p tsconfig.electron.json\" && node -e \"require('fs').copyFileSync('dist-electron/preload.js','dist-electron/preload.mjs')\" && vite build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "build": {
    "appId": "com.uptimizer.app",
    "productName": "Uptimizer",
    "icon": "resources/icon.ico",
    "files": [
      "dist/**/*",
      "!dist/win-unpacked/**",
      "!dist/release/**",
      "!dist/*.exe",
      "!dist/*.blockmap",
      "dist-electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "release"
    },
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "requireAdministrator",
      "icon": "resources/icon.ico",
      "compression": "store"
    },
    "portable": {
      "requestExecutionLevel": "admin",
      "unpackDirName": false
    },
    "mac": {
      "icon": "resources/icon.png"
    },
    "linux": {
      "icon": "resources/icon.png"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.395.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.0"
  }
}
